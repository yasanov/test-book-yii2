# Application Configuration
YII_ENV=dev
YII_DEBUG=1
COOKIE_VALIDATION_KEY=change-me-to-a-random-secret

# Database Configuration
# Set DOCKER_ENV=1 when running inside docker-compose
DOCKER_ENV=0

# Storage Configuration
STORAGE_DRIVER=local
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-central1
S3_ENDPOINT=https://storage.yandexcloud.net
S3_PATH_PREFIX=

# SMS Configuration (smspilot.ru)
# For testing you can use the emulator key below.
SMS_API_KEY=XXXXXXXXXXXXYYYYYYYYYYYYZZZZZZZZXXXXXXXXXXXXYYYYYYYYYYYYZZZZZZZZ1234
SMS_API_URL=https://smspilot.ru/api.php
SMS_IS_EMULATOR=1
